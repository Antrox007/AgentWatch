{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentWatch",
  "version": "0.1.0",
  "identifier": "app.agentwatch.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentWatch",
        "width": 440,
        "height": 700,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "shadow": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "AgentWatch",
    "category": "DeveloperTool",
    "shortDescription": "Live-Monitor fuer aktive Claude-Code-Sessions",
    "longDescription": "AgentWatch zeigt deine aktiven Claude-Code-Sessions, deren Status und die Anzahl laufender Agents in Echtzeit im System-Tray.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
